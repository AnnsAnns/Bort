---
import BaseLayout from '../layouts/BaseLayout.astro';
import Box from '../components/Box.astro';
import LatestBlogpost from '../components/LatestBlogpost.astro';
import ClickToSeeMore from '../components/ClickToSeeMore.astro';
import LatestRambling from '../components/LatestRambling.astro';
import Blinkies from '../components/Blinkies.astro';

---

<BaseLayout>
<div class="
	flex
	xl:flex-row
	flex-col
	flex-wrap
	h-full
	gap-5
	justify-start
	content-start
	items-center
	overflow-y-scroll
	w-full"
	>
	<div class="w-full xl:w-[60%]">
		<LatestBlogpost />
	</div>
	<div class="w-full xl:w-1/3">
		<a href="/friends">
			<Box title="😎 Friends" createRandomness>
				Links to some cool people

				<ClickToSeeMore/>
			</Box>
		</a>
	</div>
	<div class="w-full xl:w-1/3">
		<a href="/blog/the_internet_does_forget/">
			<Box title="⭐ Cool Post" createRandomness>
				<div class='font-headerf text-lg'>
					The Internet Does Forget
				  </div>
				  <div class='text-base-text-color/60 text-sm'>
					The only post with a reference section
				  </div>
				  <ClickToSeeMore/>
			</Box>
		</a>
	</div>
	<div class="w-full xl:w-1/3">
		<Box title="🐸 About Me" createRandomness>
			I'm AnnsAnn, a software engineer for technical systems.<br/>
			I procrastinate by making websites and open source projects.
		</Box>
	</div>
	<div class="w-full xl:w-1/4">
		<Box title="✉️ Contact" createRandomness>
			You can contact me via <a class="font-bold underline" href="mailto:blog@annsann.eu">email</a>. <br/> I don't care about your crypto startup though.
		</Box>
	</div>
	<div class="w-full xl:w-[45%]">
		<a href="/projects">
			<Box title="🔥 Projects" createRandomness>
				A showcase of some of my projects.<br/>
				All of them are open source 🐸
				<ClickToSeeMore/>
			</Box>
		</a>
	</div>
	<div class="w-full xl:w-[45%]">
		<a href="https://github.com/AnnsAnns">
			<Box title="🤝 Github" createRandomness>
				Nearly all my projects are Open Source and on Github.<br/>
				Including the source code for this site.
				<ClickToSeeMore/>
			</Box>
		</a>
	</div>
	<div class="w-full xl:w-1/2">
		<Box title="🚅 Vanilla Astro" createRandomness>
			<p class="">
				This site is completely vanilla, no react, no vue, no svelte, no angular, no jquery, no nothing. 100/100 Lighthouse.
			</p>
		</Box>
	</div>
	<div class="w-full md:w-1/2 xl:w-1/3">
		<LatestRambling />
	</div>

	<!-- <div class="w-fit">
		<Box title="Blinkies" createRandomness>
			<div class="flex flex-wrap gap-1">
				<Blinkies/>
			</div>
		</Box>
	</div> -->
</div>
</BaseLayout>